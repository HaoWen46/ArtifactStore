# Eval result dirs: the report's tables are computed from committed
# result.jsonl / manifest.json / config.json / audit.csv inside each run dir.
# Per-run *.sqlite DBs are excluded by the global *.sqlite rule above
# (they are large and re-derivable by replaying fixtures through the driver).
eval/runs/*/__pycache__/
artifactstore_data/

# Claude Code local-only settings
.claude/settings.local.json

# Sub-cloned reference repos carry their own .git — don't track them
notes/references/*/

# Local env files — API keys etc. Never commit.
.env
.env.*
!.env.example
.coverage
