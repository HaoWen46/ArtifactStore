# Copy to `.env` (gitignored). Fill in the keys you have; leave the
# others as-is. Both providers coexist — the runner picks credentials
# from the model name prefix:
#   deepseek-*  -> DEEPSEEK_API_KEY + DEEPSEEK_BASE_URL
#   qwen*       -> QWEN_API_KEY     + QWEN_BASE_URL
# No cross-provider fallback: each provider reads only its own env vars.
# Verify wiring with: `uv run python -m demo.runner --check-config --model <name>`

# --- DeepSeek V4 — https://platform.deepseek.com/api_keys -------------------
DEEPSEEK_API_KEY=sk-REPLACE-ME
DEEPSEEK_BASE_URL=https://api.deepseek.com/anthropic
DEEPSEEK_MODEL=deepseek-v4-pro

# --- Qwen via Alibaba Cloud Model Studio (intl tenant) ----------------------
# Keys: https://modelstudio.console.alibabacloud.com
# Mainland-CN tenants replace QWEN_BASE_URL with
#   https://dashscope.aliyuncs.com/apps/anthropic
QWEN_API_KEY=sk-REPLACE-ME
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/apps/anthropic
QWEN_MODEL=qwen3.6-plus
