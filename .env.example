# Copy to `.env` (gitignored). Fill in whichever provider keys you have.
# All three coexist — the runner picks credentials from the model name:
#   deepseek-*  -> DEEPSEEK_API_KEY (+ DEEPSEEK_BASE_URL)
#   qwen-*      -> QWEN_API_KEY     (+ QWEN_BASE_URL)
#   claude-*    -> ANTHROPIC_API_KEY (+ ANTHROPIC_BASE_URL)
# No cross-provider fallback: each provider only reads its own env vars.
# Verify wiring with: `uv run python -m demo.runner --check-config --model <name>`

# --- DeepSeek V4 — https://platform.deepseek.com/api_keys -------------------
# Models: deepseek-v4-pro (eval headline), deepseek-v4-flash (cheaper).
DEEPSEEK_API_KEY=sk-...
# DEEPSEEK_BASE_URL=        # only set for self-hosted / regional override

# --- Qwen3.6 via Alibaba Cloud Model Studio --------------------------------
# Keys: https://modelstudio.console.alibabacloud.com  (international)
#       https://bailian.console.aliyun.com            (mainland CN)
# Models: qwen3.6-max, qwen3.6-235b-a22b-instruct, qwen3.6-32b-instruct,
#         qwen3.6-coder-32b-instruct, qwen3.6-plus.
QWEN_API_KEY=sk-...
# QWEN_BASE_URL=            # default is intl tenant; mainland-CN users set
                            # https://dashscope.aliyuncs.com/api/v2/apps/anthropic

# --- Native Anthropic — https://console.anthropic.com ----------------------
# Models: claude-sonnet-4-5, claude-haiku-4-5, claude-opus-4-7.
# Prefer snapshot-pinned IDs (e.g. claude-sonnet-4-5-20250929) for repro.
ANTHROPIC_API_KEY=sk-ant-api03-...
# ANTHROPIC_BASE_URL=       # leave unset; SDK default = api.anthropic.com
