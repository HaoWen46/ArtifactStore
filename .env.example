# ArtifactStore demo runner / eval driver load this on startup
# (see demo/runner.py::load_dotenv). Copy to `.env` (gitignored) and
# fill in whichever provider keys you have. *Both providers can be
# configured simultaneously*: the runner picks the right credentials
# automatically from the model name you pass via `--model`. There is
# no global "active provider" toggle — that lets a single sweep run
# `--model deepseek-v4-pro` and `--model qwen3.6-max` back to back
# without touching this file.
#
# Resolution rules (demo/providers.py):
#   model starts with "deepseek" → DEEPSEEK_API_KEY  + DEEPSEEK_BASE_URL
#   model starts with "qwen"     → QWEN_API_KEY      + QWEN_BASE_URL
#   model starts with "claude"   → ANTHROPIC_API_KEY + ANTHROPIC_BASE_URL
#   anything else                → ANTHROPIC_API_KEY + ANTHROPIC_BASE_URL
# Each provider reads its own env vars; there is *no* cross-provider
# fallback for either keys or URLs. A bare `ANTHROPIC_API_KEY` does
# not authenticate DeepSeek or Qwen requests — that would silently
# misroute credentials and surface as a confusing 401. If you are
# migrating from an older single-env-var .env (only ANTHROPIC_API_KEY +
# ANTHROPIC_BASE_URL=https://api.deepseek.com/anthropic), rename
# ANTHROPIC_API_KEY → DEEPSEEK_API_KEY and drop ANTHROPIC_BASE_URL
# (the DeepSeek URL is now the provider's default).
#
# Pre-flight (run these before any paid sweep — they catch ~every
# misconfiguration we have seen):
#   uv run python -m demo.runner --check-config --model deepseek-v4-pro
#   uv run python -m demo.runner --check-config --model qwen3.6-max
#   uv run python -m demo.runner --verify-tool-use     --model <name>
#   uv run python -m demo.runner --verify-tool-choice  --model <name>


# --- DeepSeek V4 (eval headline provider) ------------------------------------
# Get a key: https://platform.deepseek.com/api_keys
# Recommended models (pass via --model):
#   deepseek-v4-pro       — reasoning model; eval headline; slower
#   deepseek-v4-flash     — cheaper iteration; faster, less accurate
# Pricing (May 2026 promo): $0.435/M in cache-miss, $0.0036/M cache-hit,
#                           $0.87/M out.
DEEPSEEK_API_KEY=sk-...
# Override only if pointing at a self-hosted DeepSeek shim or a regional
# endpoint. Defaults to https://api.deepseek.com/anthropic.
# DEEPSEEK_BASE_URL=


# --- Qwen3.6 via Alibaba Cloud Model Studio (second model family) ------------
# Get a key:
#   International: https://modelstudio.console.alibabacloud.com
#   Mainland CN:   https://bailian.console.aliyun.com
# Recommended models (pass via --model):
#   qwen3.6-max                    — flagship dense (Sonnet-class)
#   qwen3.6-235b-a22b-instruct     — MoE flagship; 235B total / 22B active
#   qwen3.6-32b-instruct           — mid-tier dense, cheaper
#   qwen3.6-coder-32b-instruct     — code-tuned (matches diagnostic workload)
#   qwen3.6-plus                   — balanced cost/quality alias
# QWEN_API_KEY=sk-...
# Endpoint path varies by tenant. The default is the International tenant's
# Anthropic-Messages-compatible path. Mainland-CN users typically set:
#   QWEN_BASE_URL=https://dashscope.aliyuncs.com/api/v2/apps/anthropic
# Override here if your account routes differently — `--check-config` and
# `--verify-tool-use` will surface the exact error before any paid spend.
# QWEN_BASE_URL=


# --- Native Anthropic (third model family / fallback) ------------------------
# Get a key: https://console.anthropic.com
# Recommended models (pass via --model):
#   claude-sonnet-4-5     — primary comparison target for the second-model
#                            sweep (DeepSeek-Pro-class)
#   claude-sonnet-4-5-20250929  — snapshot-pinned; prefer for reproducible reps
#   claude-haiku-4-5      — cheaper, faster iteration
#   claude-opus-4-7       — flagship; ~6× Sonnet cost
# ANTHROPIC_API_KEY=sk-ant-api03-...
# Omit ANTHROPIC_BASE_URL — SDK default = https://api.anthropic.com.
# ANTHROPIC_BASE_URL=
