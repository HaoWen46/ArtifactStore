# ArtifactStore demo runner reads these on startup (see demo/runner.py::load_dotenv).
# Copy this file to `.env` (which is gitignored) and fill in your provider key.

# --- DeepSeek (default, recommended) -----------------------------------------
# Get a key at https://platform.deepseek.com/api_keys
ANTHROPIC_API_KEY=sk-...
ANTHROPIC_BASE_URL=https://api.deepseek.com/anthropic

# --- Native Anthropic (alternate) --------------------------------------------
# Comment the two lines above and uncomment the line below.
# ANTHROPIC_API_KEY=sk-ant-api03-...
